# ============================================================
# Finance Monitoring AI System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_KEY=<your-service-role-key>       # backend only, never expose to frontend
SUPABASE_DB_PASSWORD=<your-db-password>
SUPABASE_PROJECT_ID=<your-project-ref>             # e.g. abcdefghijklmnop
SUPABASE_ACCESS_TOKEN=<your-personal-access-token> # for Supabase CLI in CI

# ── Google Gemini ──────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-1.5-pro-latest

# ── FastAPI Backend ───────────────────────────────────────────
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
SECRET_KEY=<random-32-char-string>                 # for JWT signing; run: openssl rand -hex 32

# ── Next.js Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000           # change to Render URL in production
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# ── Monitoring & Logging ──────────────────────────────────────
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>  # Next.js errors
LOGTAIL_TOKEN=<your-logtail-source-token>                   # FastAPI structured logs
UPTIMEROBOT_API_KEY=<your-uptimerobot-key>                  # optional, for setup script

# ── CI/CD ─────────────────────────────────────────────────────
RENDER_API_KEY=<your-render-api-key>
RENDER_SERVICE_ID=<your-render-service-id>
VERCEL_TOKEN=<your-vercel-token>
VERCEL_ORG_ID=<your-vercel-org-id>
VERCEL_PROJECT_ID=<your-vercel-project-id>
SNYK_TOKEN=<your-snyk-token>
